generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  OWNER
  ACTIVITY_PROVIDER
  TRAVEL_AGENCY
  DEVELOPER
  ADMIN
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeveloperProjectStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityTravelRegion {
  INSIDE_OMAN
  OUTSIDE_OMAN
}

enum PriceQualifier {
  FIXED
  FROM
  ON_REQUEST
}

enum PriceUnit {
  TOTAL
  NIGHT
  MONTH
  YEAR
  PERSON
  GROUP
  HOUR
  DAY
  ACTIVITY
}

enum BookingStatus {
  PENDING
  OWNER_APPROVED
  OWNER_REJECTED
  ADMIN_CONFIRMED
  CANCELLATION_REQUESTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  NOT_REQUIRED
}

enum InquiryType {
  PROPERTY
  ACTIVITY
  DEVELOPER_PARTNERSHIP
  OWNER_PARTNERSHIP
  GENERAL
}

enum NotificationType {
  ACCOUNT_SECURITY
  BOOKING_CREATED
  BOOKING_OWNER_APPROVED
  BOOKING_OWNER_REJECTED
  BOOKING_ADMIN_CONFIRMED
  BOOKING_CANCELLATION_REQUESTED
  BOOKING_CANCELLED
  BOOKING_PAYMENT_PAID
  BOOKING_PAYMENT_FAILED
  RENT_PAYMENT_DUE
  TRANSACTION_STATUS_UPDATED
  REVIEW_STATUS_UPDATED
  VERIFICATION_STATUS_UPDATED
  SAVED_SEARCH_MATCH
}

enum EmailDeliveryStatus {
  LOGGED
  SENT
  SKIPPED
  FAILED
}

enum AccountSecurityEventType {
  PASSWORD_CHANGED
  PASSWORD_RESET_COMPLETED
  LOGOUT_ALL_SESSIONS
  EMAIL_CHANGE_REQUESTED
  EMAIL_CHANGE_CONFIRMED
  ADMIN_USER_SUSPENDED
  ADMIN_USER_UNSUSPENDED
  ADMIN_EMAIL_VERIFIED
  ADMIN_EMAIL_UNVERIFIED
  ACCOUNT_DEACTIVATED
}

enum BookingEventType {
  BOOKING_CREATED
  OWNER_APPROVED
  OWNER_REJECTED
  ADMIN_CONFIRMED
  CANCELLATION_REQUESTED
  CANCELLED
  PAYMENT_SESSION_CREATED
  PAYMENT_PAID
  PAYMENT_FAILED
}

enum ListingBuyerEligibility {
  OMANI_ONLY
  GCC_NATIONALS
  OMAN_RESIDENTS
  FOREIGNERS_ALLOWED
  COMPANY_PURCHASE_ALLOWED
  FREEHOLD
  USUFRUCT
  EXPAT_BUYABLE
  ITC
  GOLDEN_VISA_ELIGIBLE
  OMR_250K_RESIDENCY_ELIGIBLE
  OMR_500K_RESIDENCY_ELIGIBLE
}

enum MediaAssetType {
  IMAGE
  VIDEO_WALKTHROUGH
  TOUR_360
  VIRTUAL_TOUR
  FLOOR_PLAN
  DOCUMENT
  OTHER
}

enum MediaQualityStatus {
  NOT_CHECKED
  NEEDS_REVIEW
  ACCEPTABLE
  EXCELLENT
  BLOCKED
}

enum EnhancementStatus {
  NOT_REQUESTED
  NOT_CONFIGURED
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum VerificationStatus {
  UNVERIFIED
  SUBMITTED
  ADMIN_VERIFIED
  EXTERNALLY_VERIFIED
  REJECTED
  EXPIRED
}

enum VerificationSource {
  LUX_OM_ADMIN_REVIEW
  OWNER_DOCUMENT_SUBMISSION
  FUTURE_MOLUP_API
  FUTURE_MUNICIPALITY_REGISTRATION
  FUTURE_THIRD_PARTY_PROVIDER
}

enum VerificationTargetType {
  LISTING
  ACTIVITY
  DEVELOPER
  TRAVEL_AGENCY
  USER
  CONTRACT
  TRANSACTION
}

enum ContractDraftStatus {
  DRAFT
  READY_FOR_REVIEW
  SIGNED_EXTERNALLY
  ARCHIVED
}

enum ContractRegistrationStatus {
  NOT_STARTED
  PREPARED_FOR_REGISTRATION
  DRAFT_READY_FOR_SUBMISSION
  SUBMITTED_EXTERNALLY
  REGISTERED_EXTERNALLY
  REJECTED
  NEEDS_CHANGES
}

enum PaymentScheduleFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RentPaymentStatus {
  PENDING
  DUE_SOON
  OVERDUE
  PAID
  CANCELLED
}

enum MarketplaceTransactionType {
  PROPERTY_SALE
  PROPERTY_RENTAL
  ACTIVITY_BOOKING
  PROVIDER_PAYOUT
  OTHER
}

enum MarketplaceTransactionStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
  ARCHIVED
}

enum TransactionParticipantRole {
  BUYER
  SELLER
  LANDLORD
  TENANT
  PROVIDER
  ADMIN
}

enum EscrowStatus {
  NOT_STARTED
  PENDING_DEPOSIT
  HELD
  RELEASE_REQUESTED
  RELEASED
  DISPUTED
  CANCELLED
}

enum TransactionEventType {
  CREATED
  STATUS_CHANGED
  ESCROW_STATUS_CHANGED
  DOCUMENT_ADDED
  PAYMENT_LINK_CREATED
  ADMIN_NOTE
  REVIEWED
}

enum ModerationTargetType {
  LISTING
  ACTIVITY
  TRAVEL_AGENCY
  DEVELOPER
  REVIEW
  USER
  OTHER
}

enum ReportReason {
  MISLEADING_INFO
  SUSPECTED_FRAUD
  DUPLICATE
  INAPPROPRIATE_CONTENT
  WRONG_PRICE
  UNAVAILABLE
  SAFETY_CONCERN
  OTHER
}

enum ModerationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  RESOLVED
  DISMISSED
}

enum ReviewTargetType {
  ACTIVITY
  TRAVEL_AGENCY
  DEVELOPER
  LISTING
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum SavedSearchAlertFrequency {
  NONE
  DASHBOARD_ONLY
  DAILY
  WEEKLY
}

enum ValuationStatus {
  REQUESTED
  LOW_DATA_READY
  ESTIMATE_READY
  NEEDS_REVIEW
  APPROVED
  ARCHIVED
}

enum ValuationConfidence {
  LOW_DATA
  MEDIUM_DATA
  HIGH_DATA
}

enum ValuationReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_MORE_DATA
}

enum DocumentChecklistStatus {
  NOT_REQUIRED
  REQUIRED
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  passwordLoginEnabled       Boolean   @default(true)
  authTokenVersion           Int       @default(0)
  suspendedAt                DateTime?
  suspendedReason            String?
  suspendedById              String?
  deactivatedAt              DateTime?
  deactivationReason         String?
  suspendedBy                User?     @relation("UserSuspensionsIssued", fields: [suspendedById], references: [id], onDelete: SetNull)
  suspensionsIssued          User[]    @relation("UserSuspensionsIssued")
  role      Role     @default(USER)
  googleId                    String?   @unique
  phone                       String?
  companyName                 String?
  emailVerified               Boolean   @default(false)
  emailVerifiedAt             DateTime?
  emailVerificationTokenHash  String?   @unique
  emailVerificationExpiresAt  DateTime?
  pendingEmail                String?   @unique
  emailBookingUpdates          Boolean   @default(true)
  emailSavedSearchUpdates      Boolean   @default(true)
  emailMarketingUpdates        Boolean   @default(false)
  emailChangeTokenHash        String?   @unique
  emailChangeExpiresAt        DateTime?
  passwordResetTokenHash      String?   @unique
  passwordResetExpiresAt      DateTime?
  passwordResetUsedAt         DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  listings      Listing[]
  developerProjects DeveloperProject[]
  activities    Activity[]
  bookings      Booking[]
  inquiries     Inquiry[]
  notifications Notification[] @relation("UserNotifications")
  accountSecurityEvents AccountSecurityEvent[] @relation("AccountSecurityEventUser")
  accountSecurityEventsActed AccountSecurityEvent[] @relation("AccountSecurityEventActor")
  bookingEvents BookingEvent[] @relation("BookingEventActor")
  oauthLoginCodes OauthLoginCode[]

  eligibilityMarkedListings       Listing[]          @relation("ListingEligibilityMarkedBy")
  listingVerificationReviews      Listing[]          @relation("ListingVerificationReviewedBy")
  activityVerificationReviews     Activity[]         @relation("ActivityVerificationReviewedBy")
  developerVerificationReviews    DeveloperCompany[] @relation("DeveloperVerificationReviewedBy")
  travelAgencyVerificationReviews TravelAgency[]     @relation("TravelAgencyVerificationReviewedBy")

  contractDraftsCreated RentalContractDraft[] @relation("ContractCreatedBy")
  contractsAsLandlord   RentalContractDraft[] @relation("ContractLandlord")
  contractsAsTenant     RentalContractDraft[] @relation("ContractTenant")

  rentSchedulesCreated    RentPaymentSchedule[] @relation("RentScheduleCreatedBy")
  rentSchedulesAsLandlord RentPaymentSchedule[] @relation("RentScheduleLandlord")
  rentSchedulesAsTenant   RentPaymentSchedule[] @relation("RentScheduleTenant")

  transactionsAsBuyer    MarketplaceTransaction[] @relation("TransactionBuyer")
  transactionsAsSeller   MarketplaceTransaction[] @relation("TransactionSeller")
  transactionsAsLandlord MarketplaceTransaction[] @relation("TransactionLandlord")
  transactionsAsTenant   MarketplaceTransaction[] @relation("TransactionTenant")
  transactionsAsProvider MarketplaceTransaction[] @relation("TransactionProvider")
  transactionsAsAdmin    MarketplaceTransaction[] @relation("TransactionAdmin")

  transactionParticipants TransactionParticipant[]
  transactionAuditEvents  TransactionAuditEvent[]  @relation("TransactionAuditActor")

  paymentLedgerAsPayer MarketplacePaymentLedger[] @relation("PaymentLedgerPayer")
  paymentLedgerAsPayee MarketplacePaymentLedger[] @relation("PaymentLedgerPayee")

  valuationRequestsRequested ValuationRequest[] @relation("ValuationRequestedBy")
  valuationRequestsReviewed  ValuationRequest[] @relation("ValuationReviewedBy")

  verificationRecordsSubmitted VerificationRecord[]    @relation("VerificationSubmittedBy")
  verificationRecordsReviewed  VerificationRecord[]    @relation("VerificationReviewedBy")
  documentChecklistReviews     DocumentChecklistItem[] @relation("DocumentChecklistReviewedBy")

  trustReportsSubmitted TrustReport[] @relation("TrustReportSubmittedBy")
  trustReportsReviewed  TrustReport[] @relation("TrustReportReviewedBy")

  reviewsWritten   Review[] @relation("ReviewWrittenBy")
  reviewsModerated Review[] @relation("ReviewModeratedBy")

  savedListings          SavedListing[]
  savedActivities        SavedActivity[]
  savedSearches          SavedSearch[]
  investorWatchlistItems InvestorWatchlistItem[]

  @@index([role])
  @@index([suspendedAt])
  @@index([deactivatedAt])
  @@index([suspendedById])
  @@index([googleId])
  @@index([emailVerified])
  @@index([emailVerificationExpiresAt])
  @@index([emailChangeExpiresAt])
  @@index([passwordResetExpiresAt])
  @@index([passwordResetUsedAt])
  @@index([createdAt])
}

model Landmark {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEn    String
  nameAr    String?
  cityEn    String
  cityAr    String?
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings   Listing[]
  activities Activity[]
  developerProjects DeveloperProject[]

  @@index([cityEn])
  @@index([category])
}

model DeveloperCompany {
  id              String  @id @default(cuid())
  slug            String  @unique
  nameEn          String
  nameAr          String?
  descriptionEn   String?
  descriptionAr   String?
  headquartersEn  String?
  headquartersAr  String?
  logo            String?
  phone           String?
  email           String?
  website         String?
  establishedYear Int?
  verified        Boolean @default(false)
  featured        Boolean @default(false)

  verificationStatus       VerificationStatus  @default(UNVERIFIED)
  verificationSource       VerificationSource?
  verificationNotes        String?
  verificationDate         DateTime?
  verificationExpiryDate   DateTime?
  verificationReviewedById String?
  verificationReviewedBy   User?               @relation("DeveloperVerificationReviewedBy", fields: [verificationReviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]
  projects DeveloperProject[]
  reviews  Review[]

  @@index([verified])
  @@index([featured])
  @@index([verificationStatus])
  @@index([verificationReviewedById])
}

model TravelAgency {
  id              String  @id @default(cuid())
  slug            String  @unique
  nameEn          String
  nameAr          String?
  descriptionEn   String?
  descriptionAr   String?
  headquartersEn  String?
  headquartersAr  String?
  logo            String?
  phone           String?
  email           String?
  website         String?
  establishedYear Int?
  verified        Boolean @default(false)
  featured        Boolean @default(false)

  verificationStatus       VerificationStatus  @default(UNVERIFIED)
  verificationSource       VerificationSource?
  verificationNotes        String?
  verificationDate         DateTime?
  verificationExpiryDate   DateTime?
  verificationReviewedById String?
  verificationReviewedBy   User?               @relation("TravelAgencyVerificationReviewedBy", fields: [verificationReviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]
  reviews    Review[]

  @@index([verified])
  @@index([featured])
  @@index([verificationStatus])
  @@index([verificationReviewedById])
}

model DeveloperProject {
  id   String @id @default(cuid())
  slug String @unique

  nameEn        String
  nameAr        String?
  descriptionEn String?
  descriptionAr String?
  locationEn    String
  locationAr    String?

  mapPlaceLabel String?
  mapAddress    String?
  mapGoogleUrl  String?
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)

  completionStatus String?
  handoverDate     DateTime?
  totalUnits       Int?
  availableUnits   Int?
  bedroomsSummary  String?
  amenities        String[] @default([])
  paymentPlan      String?
  brochureUrl      String?
  masterplanUrl    String?
  videoWalkthroughUrl String?
  image            String?

  mediaQualityStatus  MediaQualityStatus @default(NOT_CHECKED)
  mediaQualityNotes   String?
  enhancedImageUrl    String?
  enhancementStatus   EnhancementStatus  @default(NOT_REQUESTED)
  enhancementProvider String?
  enhancementNotes    String?

  startingPriceAmount Decimal?       @db.Decimal(14, 3)
  priceCurrency       String?        @db.VarChar(3)
  priceQualifier      PriceQualifier @default(FROM)

  status         DeveloperProjectStatus @default(PENDING)
  rejectedReason String?

  developerId String
  developer   DeveloperCompany @relation(fields: [developerId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  nearestLandmarkId String?
  nearestLandmark   Landmark? @relation(fields: [nearestLandmarkId], references: [id], onDelete: SetNull)

  images   DeveloperProjectImage[]
  listings Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([developerId])
  @@index([ownerId])
  @@index([nearestLandmarkId])
  @@index([latitude, longitude])
  @@index([mediaQualityStatus])
}

model DeveloperProjectImage {
  id        String @id @default(cuid())
  url       String
  altEn     String?
  altAr     String?
  sortOrder Int    @default(0)

  projectId String
  project   DeveloperProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model Listing {
  id   String @id @default(cuid())
  slug String @unique

  title            String
  description      String
  type             String
  transaction      String
  buyerEligibility ListingBuyerEligibility[] @default([])
  location         String

  mapPlaceLabel String?
  mapAddress    String?
  mapGoogleUrl  String?
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)

  titleEn       String?
  titleAr       String?
  descriptionEn String?
  descriptionAr String?
  locationEn    String?
  locationAr    String?
  typeEn        String?
  typeAr        String?

  price          String
  priceAmount    Decimal?       @db.Decimal(14, 3)
  priceCurrency  String?        @db.VarChar(3)
  priceQualifier PriceQualifier @default(FIXED)
  priceUnit      PriceUnit?

  beds           Int
  baths          Int
  sqm            Int
  image          String
  status         ListingStatus @default(PENDING)
  rejectedReason String?
  partnerTier    Int           @default(0)

  maxGuests        Int?
  minStayNights    Int?
  parking          Boolean?
  floor            Int?
  furnishing       String?
  view             String?
  paymentFrequency String?

  eligibilityMarkedById  String?
  eligibilityMarkedBy    User?    @relation("ListingEligibilityMarkedBy", fields: [eligibilityMarkedById], references: [id], onDelete: SetNull)
  eligibilityNotes       String?
  eligibilityDisclaimer  String?
  adminVerificationNotes String?
  investorHighlights     String[] @default([])

  videoWalkthroughUrl String?
  tour360Url          String?
  virtualTourUrl      String?
  floorPlanUrl        String?

  mediaQualityStatus  MediaQualityStatus @default(NOT_CHECKED)
  mediaQualityNotes   String?
  enhancedImageUrl    String?
  enhancementStatus   EnhancementStatus  @default(NOT_REQUESTED)
  enhancementProvider String?
  enhancementNotes    String?

  verificationStatus       VerificationStatus  @default(UNVERIFIED)
  verificationSource       VerificationSource?
  verificationNotes        String?
  verificationDate         DateTime?
  verificationExpiryDate   DateTime?
  verificationReviewedById String?
  verificationReviewedBy   User?               @relation("ListingVerificationReviewedBy", fields: [verificationReviewedById], references: [id], onDelete: SetNull)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  developerId     String?
  developer       DeveloperCompany? @relation(fields: [developerId], references: [id], onDelete: SetNull)
  developerNameEn String?
  developerNameAr String?

  developerProjectId String?
  developerProject   DeveloperProject? @relation(fields: [developerProjectId], references: [id], onDelete: SetNull)

  nearestLandmarkId      String?
  nearestLandmark        Landmark? @relation(fields: [nearestLandmarkId], references: [id], onDelete: SetNull)
  distanceFromLandmarkEn String?
  distanceFromLandmarkAr String?

  amenities         Amenity[]
  images            ListingImage[]
  premiumMedia      PremiumMediaAsset[]
  bookings          Booking[]
  inquiries         Inquiry[]
  contractDrafts    RentalContractDraft[]
  rentSchedules     RentPaymentSchedule[]
  transactions      MarketplaceTransaction[]
  valuationRequests ValuationRequest[]
  reviews           Review[]
  savedBy           SavedListing[]
  watchlistItems    InvestorWatchlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([status, partnerTier, createdAt])
  @@index([status, priceAmount])
  @@index([ownerId])
  @@index([developerId])
  @@index([developerProjectId])
  @@index([nearestLandmarkId])
  @@index([latitude, longitude])
  @@index([location])
  @@index([transaction])
  @@index([eligibilityMarkedById])
  @@index([verificationStatus])
  @@index([mediaQualityStatus])
}

model Amenity {
  id   String @id @default(cuid())
  name String

  nameEn String?
  nameAr String?

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingImage {
  id        String  @id @default(cuid())
  url       String
  altEn     String?
  altAr     String?
  sortOrder Int     @default(0)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([listingId])
}

model Activity {
  id   String @id @default(cuid())
  slug String @unique

  titleEn       String
  titleAr       String?
  descriptionEn String
  descriptionAr String?
  locationEn    String
  locationAr    String?

  categoryEn String
  categoryAr String?
  providerEn String?
  providerAr String?

  price          String
  priceAmount    Decimal?       @db.Decimal(14, 3)
  priceCurrency  String?        @db.VarChar(3)
  priceQualifier PriceQualifier @default(FIXED)
  priceUnit      PriceUnit?

  durationMinutes Int?
  durationLabelEn String?
  durationLabelAr String?
  durationType    String?
  groupSize       String?
  capacity        Int?
  language        String?
  difficulty      String?
  activityType    String?
  travelRegion    ActivityTravelRegion @default(INSIDE_OMAN)

  destinationCountry String?
  destinationCity    String?
  departureCity      String?

  tripDurationDays   Int?
  tripDurationNights Int?

  flightIncluded Boolean @default(false)
  airline        String?
  flightNotes    String?

  hotelIncluded Boolean @default(false)
  hotelName     String?
  hotelRating   Int?
  roomType      String?
  mealPlan      String?

  visaSupportIncluded     Boolean @default(false)
  travelInsuranceIncluded Boolean @default(false)
  airportTransferIncluded Boolean @default(false)

  packageItinerary     String?
  requiredDocuments    String?
  cancellationPolicy   String?
  availableTravelDates String?
  minimumGroupSize     Int?
  packageInclusions    String?
  packageExclusions    String?

  availabilityDays      String[] @default([])
  availabilityStartTime String?
  availabilityEndTime   String?

  familyFriendly   Boolean @default(false)
  includesTransfer Boolean @default(false)
  mealIncluded     Boolean @default(false)
  outdoor          Boolean @default(false)

  videoWalkthroughUrl String?
  tour360Url          String?
  virtualTourUrl      String?

  mediaQualityStatus  MediaQualityStatus @default(NOT_CHECKED)
  mediaQualityNotes   String?
  enhancedImageUrl    String?
  enhancementStatus   EnhancementStatus  @default(NOT_REQUESTED)
  enhancementProvider String?
  enhancementNotes    String?

  verificationStatus       VerificationStatus  @default(UNVERIFIED)
  verificationSource       VerificationSource?
  verificationNotes        String?
  verificationDate         DateTime?
  verificationExpiryDate   DateTime?
  verificationReviewedById String?
  verificationReviewedBy   User?               @relation("ActivityVerificationReviewedBy", fields: [verificationReviewedById], references: [id], onDelete: SetNull)

  status         ActivityStatus @default(PENDING)
  rejectedReason String?
  partnerTier    Int            @default(0)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  travelAgencyId String?
  travelAgency   TravelAgency? @relation(fields: [travelAgencyId], references: [id], onDelete: SetNull)

  nearestLandmarkId      String?
  nearestLandmark        Landmark? @relation(fields: [nearestLandmarkId], references: [id], onDelete: SetNull)
  distanceFromLandmarkEn String?
  distanceFromLandmarkAr String?

  images       ActivityImage[]
  premiumMedia PremiumMediaAsset[]
  highlights   ActivityHighlight[]
  inquiries    Inquiry[]
  bookings     Booking[]
  transactions MarketplaceTransaction[]
  reviews      Review[]
  savedBy      SavedActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([status, partnerTier, createdAt])
  @@index([status, priceAmount])
  @@index([ownerId])
  @@index([travelAgencyId])
  @@index([nearestLandmarkId])
  @@index([categoryEn])
  @@index([travelRegion])
  @@index([verificationStatus])
  @@index([mediaQualityStatus])
}

model ActivityImage {
  id        String  @id @default(cuid())
  url       String
  altEn     String?
  altAr     String?
  sortOrder Int     @default(0)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([activityId])
}

model ActivityHighlight {
  id     String  @id @default(cuid())
  textEn String
  textAr String?

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

model PremiumMediaAsset {
  id        String         @id @default(cuid())
  type      MediaAssetType
  url       String
  provider  String?
  titleEn   String?
  titleAr   String?
  altEn     String?
  altAr     String?
  sortOrder Int            @default(0)
  isPrimary Boolean        @default(false)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([listingId, sortOrder])
  @@index([activityId, sortOrder])
}

model Booking {
  id      String        @id @default(cuid())
  message String?
  status  BookingStatus @default(PENDING)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  scheduledDate DateTime?
  preferredTime String?
  guests        Int       @default(1)

  contactName  String?
  contactEmail String?
  contactPhone String?

  cancellationReason      String?
  cancellationRequestedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payment       Payment?
  paymentLedger MarketplacePaymentLedger[]
  transactions  MarketplaceTransaction[]
  notifications Notification[]
  events        BookingEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([activityId])
  @@index([userId])
  @@index([status])
  @@index([scheduledDate])
}

model Payment {
  id         String        @id @default(cuid())
  amount     Decimal       @db.Decimal(10, 2)
  commission Decimal       @db.Decimal(10, 2)
  currency   String        @default("OMR") @db.VarChar(3)
  status     PaymentStatus @default(PENDING)

  provider             String?
  reference            String?   @unique
  providerSessionId    String?   @unique
  checkoutUrl          String?
  receiptNumber        String?   @unique
  providerPayoutAmount Decimal?  @db.Decimal(10, 2)
  paidAt               DateTime?

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([paidAt])
}

model Inquiry {
  id      String      @id @default(cuid())
  type    InquiryType
  name    String
  email   String
  phone   String?
  message String

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([userId])
  @@index([listingId])
  @@index([activityId])
  @@index([createdAt])
}

model AccountSecurityEvent {
  id       String                   @id @default(cuid())
  type     AccountSecurityEventType
  title    String
  message  String
  metadata Json?

  userId String
  user   User   @relation("AccountSecurityEventUser", fields: [userId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("AccountSecurityEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([actorId])
  @@index([type])
  @@index([createdAt])
}

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  title   String
  message String
  readAt  DateTime?

  userId String
  user   User   @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([bookingId])
  @@index([type])
}

model EmailDeliveryEvent {
  id               String              @id @default(cuid())
  status           EmailDeliveryStatus
  deliveryMode     String
  notificationType NotificationType
  title            String
  recipientUserId  String?
  recipientEmail   String?
  actionUrl        String?
  preferencesUrl   String?
  messageId        String?
  reason           String?
  errorMessage     String?
  createdAt        DateTime            @default(now())

  @@index([status, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([recipientEmail])
  @@index([notificationType, createdAt])
}

model BookingEvent {
  id         String           @id @default(cuid())
  type       BookingEventType
  message    String?
  fromStatus BookingStatus?
  toStatus   BookingStatus?

  actorId String?
  actor   User?   @relation("BookingEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([bookingId, createdAt])
  @@index([actorId])
  @@index([type])
}

model RentalContractDraft {
  id     String              @id @default(cuid())
  title  String
  status ContractDraftStatus @default(DRAFT)

  landlordName  String
  landlordEmail String?
  landlordPhone String?

  tenantName  String
  tenantEmail String?
  tenantPhone String?

  propertyTitle   String
  propertyAddress String
  propertyType    String?
  propertyNotes   String?

  rentAmount      Decimal  @db.Decimal(12, 3)
  currency        String   @default("OMR") @db.VarChar(3)
  securityDeposit Decimal? @db.Decimal(12, 3)

  contractStartDate       DateTime?
  contractEndDate         DateTime?
  paymentSchedule         String?
  utilitiesResponsibility String?
  maintenanceTerms        String?
  noticePeriod            String?
  additionalClauses       String?
  attachmentsNotes        String?

  registrationStatus        ContractRegistrationStatus @default(NOT_STARTED)
  registrationReference     String?
  registrationDocumentUrl   String?
  registrationNotes         String?
  adminRegistrationNotes    String?
  registrationChecklist     Json?
  preparedForRegistrationAt DateTime?
  submittedExternallyAt     DateTime?
  registeredExternallyAt    DateTime?

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  landlordUserId String?
  landlordUser   User?   @relation("ContractLandlord", fields: [landlordUserId], references: [id], onDelete: SetNull)

  tenantUserId String?
  tenantUser   User?   @relation("ContractTenant", fields: [tenantUserId], references: [id], onDelete: SetNull)

  rentSchedules RentPaymentSchedule[]
  transactions  MarketplaceTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([registrationStatus])
  @@index([listingId])
  @@index([createdById])
  @@index([landlordUserId])
  @@index([tenantUserId])
}

model RentPaymentSchedule {
  id        String                   @id @default(cuid())
  title     String
  frequency PaymentScheduleFrequency @default(MONTHLY)
  amount    Decimal                  @db.Decimal(12, 3)
  currency  String                   @default("OMR") @db.VarChar(3)

  startDate     DateTime
  endDate       DateTime?
  dueDayOfMonth Int?
  active        Boolean   @default(true)
  notes         String?

  contractDraftId String?
  contractDraft   RentalContractDraft? @relation(fields: [contractDraftId], references: [id], onDelete: SetNull)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("RentScheduleCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  landlordUserId String?
  landlordUser   User?   @relation("RentScheduleLandlord", fields: [landlordUserId], references: [id], onDelete: SetNull)

  tenantUserId String?
  tenantUser   User?   @relation("RentScheduleTenant", fields: [tenantUserId], references: [id], onDelete: SetNull)

  dueItems RentPaymentDueItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([contractDraftId])
  @@index([listingId])
  @@index([createdById])
  @@index([landlordUserId])
  @@index([tenantUserId])
}

model RentPaymentDueItem {
  id          String            @id @default(cuid())
  dueDate     DateTime
  periodStart DateTime?
  periodEnd   DateTime?
  amount      Decimal           @db.Decimal(12, 3)
  currency    String            @default("OMR") @db.VarChar(3)
  status      RentPaymentStatus @default(PENDING)

  paidAt            DateTime?
  paymentProvider   String?
  paymentReference  String?   @unique
  providerSessionId String?   @unique
  checkoutUrl       String?
  receiptNumber     String?   @unique
  notes             String?

  scheduleId String
  schedule   RentPaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  ledgerEntries MarketplacePaymentLedger[]
  transactions  MarketplaceTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduleId])
  @@index([dueDate])
  @@index([status])
}

model MarketplaceTransaction {
  id           String                       @id @default(cuid())
  title        String
  type         MarketplaceTransactionType   @default(OTHER)
  status       MarketplaceTransactionStatus @default(DRAFT)
  escrowStatus EscrowStatus                 @default(NOT_STARTED)

  amount   Decimal? @db.Decimal(14, 3)
  currency String   @default("OMR") @db.VarChar(3)

  adminNotes        String?
  documentChecklist Json?
  externalProvider  String?
  providerReference String?

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  contractDraftId String?
  contractDraft   RentalContractDraft? @relation(fields: [contractDraftId], references: [id], onDelete: SetNull)

  rentDueItemId String?
  rentDueItem   RentPaymentDueItem? @relation(fields: [rentDueItemId], references: [id], onDelete: SetNull)

  buyerId String?
  buyer   User?   @relation("TransactionBuyer", fields: [buyerId], references: [id], onDelete: SetNull)

  sellerId String?
  seller   User?   @relation("TransactionSeller", fields: [sellerId], references: [id], onDelete: SetNull)

  landlordId String?
  landlord   User?   @relation("TransactionLandlord", fields: [landlordId], references: [id], onDelete: SetNull)

  tenantId String?
  tenant   User?   @relation("TransactionTenant", fields: [tenantId], references: [id], onDelete: SetNull)

  providerId String?
  provider   User?   @relation("TransactionProvider", fields: [providerId], references: [id], onDelete: SetNull)

  adminId String?
  admin   User?   @relation("TransactionAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  participants  TransactionParticipant[]
  auditEvents   TransactionAuditEvent[]
  ledgerEntries MarketplacePaymentLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([escrowStatus])
  @@index([listingId])
  @@index([activityId])
  @@index([bookingId])
  @@index([contractDraftId])
  @@index([rentDueItemId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([landlordId])
  @@index([tenantId])
  @@index([providerId])
  @@index([adminId])
}

model TransactionParticipant {
  id    String                     @id @default(cuid())
  role  TransactionParticipantRole
  name  String?
  email String?
  phone String?

  transactionId String
  transaction   MarketplaceTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([userId])
  @@index([role])
}

model TransactionAuditEvent {
  id       String               @id @default(cuid())
  type     TransactionEventType
  message  String?
  metadata Json?

  transactionId String
  transaction   MarketplaceTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("TransactionAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([transactionId, createdAt])
  @@index([actorId])
  @@index([type])
}

model MarketplacePaymentLedger {
  id                   String        @id @default(cuid())
  amount               Decimal       @db.Decimal(12, 3)
  currency             String        @default("OMR") @db.VarChar(3)
  commission           Decimal?      @db.Decimal(12, 3)
  providerPayoutAmount Decimal?      @db.Decimal(12, 3)
  status               PaymentStatus @default(PENDING)

  provider          String?
  reference         String?   @unique
  providerSessionId String?   @unique
  checkoutUrl       String?
  receiptNumber     String?   @unique
  paidAt            DateTime?
  notes             String?

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  rentDueItemId String?
  rentDueItem   RentPaymentDueItem? @relation(fields: [rentDueItemId], references: [id], onDelete: SetNull)

  transactionId String?
  transaction   MarketplaceTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  payerId String?
  payer   User?   @relation("PaymentLedgerPayer", fields: [payerId], references: [id], onDelete: SetNull)

  payeeId String?
  payee   User?   @relation("PaymentLedgerPayee", fields: [payeeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([bookingId])
  @@index([rentDueItemId])
  @@index([transactionId])
  @@index([payerId])
  @@index([payeeId])
  @@index([paidAt])
}

model MarketInsightSnapshot {
  id           String  @id @default(cuid())
  location     String
  locationKey  String
  transaction  String?
  propertyType String?

  sampleSizeSale       Int      @default(0)
  sampleSizeRent       Int      @default(0)
  avgAskingPrice       Decimal? @db.Decimal(14, 3)
  avgRent              Decimal? @db.Decimal(14, 3)
  avgPricePerSqm       Decimal? @db.Decimal(14, 3)
  estimatedRentalYield Decimal? @db.Decimal(8, 4)
  notEnoughData        Boolean  @default(false)
  notes                String?

  generatedAt DateTime @default(now())

  @@index([locationKey])
  @@index([transaction])
  @@index([propertyType])
  @@index([generatedAt])
}

model ValuationRequest {
  id           String                @id @default(cuid())
  status       ValuationStatus       @default(REQUESTED)
  confidence   ValuationConfidence   @default(LOW_DATA)
  reviewStatus ValuationReviewStatus @default(PENDING)

  propertyType String?
  location     String
  sqm          Int?
  beds         Int?
  baths        Int?
  askingPrice  Decimal? @db.Decimal(14, 3)
  rentEstimate Decimal? @db.Decimal(14, 3)
  currency     String   @default("OMR") @db.VarChar(3)

  estimateLow  Decimal? @db.Decimal(14, 3)
  estimateHigh Decimal? @db.Decimal(14, 3)

  comparableSnapshots Json?
  generatedNotes      String?
  reviewNotes         String?
  disclaimer          String?

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  requestedById String?
  requestedBy   User?   @relation("ValuationRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("ValuationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  watchlistItems InvestorWatchlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([confidence])
  @@index([reviewStatus])
  @@index([listingId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([location])
}

model VerificationRecord {
  id                String                 @id @default(cuid())
  targetType        VerificationTargetType
  targetId          String
  status            VerificationStatus     @default(SUBMITTED)
  source            VerificationSource
  notes             String?
  documentChecklist Json?
  verificationDate  DateTime?
  expiryDate        DateTime?

  submittedById String?
  submittedBy   User?   @relation("VerificationSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("VerificationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([status])
  @@index([source])
  @@index([submittedById])
  @@index([reviewedById])
  @@index([expiryDate])
}

model DocumentChecklistItem {
  id          String                  @id @default(cuid())
  targetType  VerificationTargetType
  targetId    String
  label       String
  notes       String?
  documentUrl String?
  required    Boolean                 @default(true)
  status      DocumentChecklistStatus @default(REQUIRED)

  reviewedById String?
  reviewedBy   User?   @relation("DocumentChecklistReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([status])
  @@index([reviewedById])
}

model TrustReport {
  id         String               @id @default(cuid())
  targetType ModerationTargetType
  targetId   String
  reason     ReportReason
  message    String?
  status     ModerationStatus     @default(PENDING)

  reporterName  String?
  reporterEmail String?
  reporterPhone String?

  reporterId String?
  reporter   User?   @relation("TrustReportSubmittedBy", fields: [reporterId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("TrustReportReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([reason])
  @@index([status])
  @@index([reporterId])
  @@index([reviewedById])
  @@index([createdAt])
}

model Review {
  id         String           @id @default(cuid())
  targetType ReviewTargetType
  targetId   String
  rating     Int
  title      String?
  body       String?
  status     ReviewStatus     @default(PENDING)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  travelAgencyId String?
  travelAgency   TravelAgency? @relation(fields: [travelAgencyId], references: [id], onDelete: Cascade)

  developerId String?
  developer   DeveloperCompany? @relation(fields: [developerId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation("ReviewWrittenBy", fields: [reviewerId], references: [id], onDelete: Cascade)

  moderatedById String?
  moderatedBy   User?   @relation("ReviewModeratedBy", fields: [moderatedById], references: [id], onDelete: SetNull)

  moderationNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([status])
  @@index([rating])
  @@index([activityId])
  @@index([travelAgencyId])
  @@index([developerId])
  @@index([listingId])
  @@index([reviewerId])
  @@index([moderatedById])
}

model SavedListing {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model SavedActivity {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, activityId])
  @@index([userId])
  @@index([activityId])
}

model SavedSearch {
  id             String                    @id @default(cuid())
  name           String
  category       String?
  query          String?
  filters        Json
  alertFrequency SavedSearchAlertFrequency @default(DASHBOARD_ONLY)
  alertsEnabled  Boolean                   @default(true)
  lastMatchedAt  DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([alertFrequency])
}

model InvestorWatchlistItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  valuationRequestId String?
  valuationRequest   ValuationRequest? @relation(fields: [valuationRequestId], references: [id], onDelete: SetNull)

  notes                 String?
  targetPrice           Decimal? @db.Decimal(14, 3)
  alertOnPriceChange    Boolean  @default(true)
  alertOnNewComparables Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

