  type        CrmActivityType
  status      CrmActivityStatus   @default(OPEN)
  priority    CrmActivityPriority @default(MEDIUM)
  subject     String
  body        String?
  dueAt       DateTime?
  completedAt DateTime?

  communicationDirection CrmCommunicationDirection?
  communicationOutcome   CrmCommunicationOutcome?
  templateKey            String?

  leadId String?
  lead   CrmLead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  accountId String?
  account   CrmAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  dealId String?
  deal   CrmDeal? @relation(fields: [dealId], references: [id], onDelete: Cascade)

  contactId String?
  contact   CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("CrmActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("CrmActivityAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User?   @relation("CrmActivityUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  deliveryAttempts CrmDeliveryAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, createdAt])
  @@index([leadId, createdAt])
  @@index([leadId, status, dueAt])
  @@index([accountId, createdAt])
  @@index([dealId, createdAt])
  @@index([contactId, createdAt])
  @@index([assignedToId, status, dueAt])
  @@index([leadId, type, createdAt])
  @@index([priority, status, dueAt])
  @@index([type])
}

model CrmAccount {
  id                 String         @id @default(cuid())
  workspaceId        String
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type               CrmAccountType @default(INDIVIDUAL)
  name               String
  legalName          String?
  registrationNumber String?
  taxNumber          String?
  website            String?
  email              String?
  phone              String?
  industry           String?
  notes              String?
  archivedAt         DateTime?
  pmsPropertyId      String?

  parentAccountId String?
  parentAccount   CrmAccount?  @relation("CrmAccountHierarchy", fields: [parentAccountId], references: [id], onDelete: SetNull)
  childAccounts   CrmAccount[] @relation("CrmAccountHierarchy")

  ownerUserId String?
  ownerUser   User?   @relation("CrmAccountOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  createdById String?
  updatedById String?

  contacts       CrmContact[]
  deals          CrmDeal[]
  convertedLeads CrmLead[]
  teamMembers    CrmAccountTeamMember[]
  activities     CrmActivity[]
  sourceEvents   CrmSourceEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, name])
  @@index([workspaceId, type, archivedAt])
  @@index([ownerUserId])
  @@index([parentAccountId])
  @@index([pmsPropertyId])
}

model CrmAccountTeamMember {
  id        String     @id @default(cuid())
  accountId String
  account   CrmAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("CrmAccountTeamUser", fields: [userId], references: [id], onDelete: Cascade)
  role      String     @default("MEMBER")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([accountId, userId])
  @@index([userId, active])
}

model CrmPipeline {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isDefault   Boolean   @default(false)
  active      Boolean   @default(true)
  archivedAt  DateTime?
  createdById String?
  updatedById String?

  stages CrmPipelineStage[]
  deals  CrmDeal[]
  leads  CrmLead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId, isDefault, active])
}

model CrmPipelineStage {
  id                 String               @id @default(cuid())
  pipelineId         String
  pipeline           CrmPipeline          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  key                String
  name               String
  position           Int
  type               CrmPipelineStageType @default(OPEN)
  defaultProbability Int                  @default(10)
  requiredFields     Json?
  slaHours           Int?
  active             Boolean              @default(true)
  archivedAt         DateTime?

  leads       CrmLead[]
  deals       CrmDeal[]
  fromHistory CrmStageHistory[] @relation("CrmStageHistoryFrom")
  toHistory   CrmStageHistory[] @relation("CrmStageHistoryTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pipelineId, key])
  @@unique([pipelineId, position])
  @@index([pipelineId, type, active])
}

model CrmDeal {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?

  accountId String
  account   CrmAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  primaryContactId String?
  primaryContact   CrmContact? @relation("CrmDealPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)

  sourceLeadId      String?  @unique
  sourceLead        CrmLead? @relation("CrmDealSourceLead", fields: [sourceLeadId], references: [id], onDelete: SetNull)
  convertedFromLead CrmLead? @relation("CrmLeadConvertedDeal")

  pipelineId String
  pipeline   CrmPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stageId    String
  stage      CrmPipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)

  ownerUserId String?
  ownerUser   User?   @relation("CrmDealOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  expectedValue     Decimal?            @db.Decimal(14, 3)
  currency          String              @default("OMR") @db.VarChar(3)
  probability       Int                 @default(10)
  forecastCategory  CrmForecastCategory @default(PIPELINE)
  expectedCloseDate DateTime?
  outcome           CrmDealOutcome      @default(OPEN)
  wonAt             DateTime?
  lostAt            DateTime?
  closedAt          DateTime?
  archivedAt        DateTime?
  lostReason        String?
  wonReason         String?
  reopenedCount     Int                 @default(0)
  pmsPropertyId     String?
  sourceType        CrmSourceEventType?
  sourceRecordId    String?
  createdById       String?
  updatedById       String?

  teamMembers      CrmDealTeamMember[]
  stageHistory     CrmStageHistory[]
  activities       CrmActivity[]
  scoreSnapshots   CrmScoreSnapshot[]
  sourceEvents     CrmSourceEvent[]
  deliveryAttempts CrmDeliveryAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, pipelineId, stageId, outcome])
  @@index([workspaceId, ownerUserId, expectedCloseDate])
  @@index([workspaceId, currency, outcome])
  @@index([accountId])
  @@index([primaryContactId])
  @@index([pmsPropertyId])
}

model CrmDealTeamMember {
  id        String   @id @default(cuid())
  dealId    String
  deal      CrmDeal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("CrmDealTeamUser", fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealId, userId])
  @@index([userId, active])
}

model CrmStageHistory {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId      String
  deal        CrmDeal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  pipelineId  String
  fromStageId String?
  fromStage   CrmPipelineStage? @relation("CrmStageHistoryFrom", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStageId   String
  toStage     CrmPipelineStage  @relation("CrmStageHistoryTo", fields: [toStageId], references: [id], onDelete: Restrict)
  fromOutcome CrmDealOutcome
  toOutcome   CrmDealOutcome
  reason      String?
  reopened    Boolean           @default(false)
  changedById String?
  changedBy   User?             @relation("CrmStageHistoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  changedAt   DateTime          @default(now())

  @@index([dealId, changedAt])
  @@index([workspaceId, changedAt])
}

model CrmScoreSnapshot {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          CrmLead?      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId        String?
  deal          CrmDeal?      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  score         Int
  band          CrmScoreBand
  version       String
  reasons       Json
  signals       Json
  previousScore Int?
  trend         CrmScoreTrend @default(STABLE)
  calculatedAt  DateTime      @default(now())
  jobKey        String?

  @@unique([leadId, jobKey])
  @@index([workspaceId, band, score])
  @@index([leadId, calculatedAt])
  @@index([dealId, calculatedAt])
  @@index([version, calculatedAt])
}

model CrmContactIdentity {
  id              String                 @id @default(cuid())
  workspaceId     String
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId       String
  contact         CrmContact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type            CrmContactIdentityType
  normalizedValue String
  rawValue        String
  primary         Boolean                @default(false)
  active          Boolean                @default(true)
  verifiedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([workspaceId, type, normalizedValue])
  @@index([contactId, active])
}

model CrmContactMerge {
  id                 String                @id @default(cuid())
  workspaceId        String
  workspace          Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  primaryContactId   String
  primaryContact     CrmContact            @relation("CrmContactMergePrimary", fields: [primaryContactId], references: [id], onDelete: Restrict)
  duplicateContactId String
  duplicateContact   CrmContact            @relation("CrmContactMergeDuplicate", fields: [duplicateContactId], references: [id], onDelete: Restrict)
  status             CrmContactMergeStatus @default(PREVIEWED)
  preview            Json
  conflicts          Json
  mergedAt           DateTime?
  actorId            String?
  createdAt          DateTime              @default(now())

  @@index([workspaceId, status, createdAt])
  @@index([primaryContactId])
  @@index([duplicateContactId])
}

model CrmSourceEvent {
  id             String                  @id @default(cuid())
  workspaceId    String
  workspace      Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type           CrmSourceEventType
  sourceRecordId String
  ruleKey        String
  occurredAt     DateTime
  consentStatus  CrmContactConsentStatus @default(UNKNOWN)
  contactId      String?
  contact        CrmContact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  leadId         String?
  lead           CrmLead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  accountId      String?
  account        CrmAccount?             @relation(fields: [accountId], references: [id], onDelete: SetNull)
  dealId         String?
  deal           CrmDeal?                @relation(fields: [dealId], references: [id], onDelete: SetNull)
  metadata       Json?
  createdAt      DateTime                @default(now())

  @@unique([workspaceId, type, sourceRecordId, ruleKey])
  @@index([workspaceId, type, occurredAt])
  @@index([contactId])
  @@index([leadId])
}

model CrmContactChannelPreference {
  id              String                  @id @default(cuid())
  workspaceId     String
  workspace       Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId       String
  contact         CrmContact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel         CrmCommunicationChannel
  status          CrmContactConsentStatus @default(UNKNOWN)
  lawfulBasis     String?
  preferred       Boolean                 @default(false)
  quietHoursStart Int?
  quietHoursEnd   Int?
  timezone        String?
  optedOutAt      DateTime?
  updatedById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([contactId, channel])
  @@index([workspaceId, status, channel])
}

model CrmSuppressionEntry {
  id                    String                  @id @default(cuid())
  workspaceId           String
  workspace             Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel               CrmCommunicationChannel
  normalizedDestination String
  reason                CrmSuppressionReason
  active                Boolean                 @default(true)
  source                String?
  notes                 String?
  expiresAt             DateTime?
  createdById           String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@unique([workspaceId, channel, normalizedDestination])
  @@index([workspaceId, active, channel])
  @@index([expiresAt])
}

model CrmCommunicationTemplate {
  id          String                            @id @default(cuid())
  workspaceId String
  workspace   Workspace                         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key         String
  name        String
  channel     CrmCommunicationChannel
  active      Boolean                           @default(true)
  createdById String?
  updatedById String?
  versions    CrmCommunicationTemplateVersion[]
  createdAt   DateTime                          @default(now())
  updatedAt   DateTime                          @updatedAt

  @@unique([workspaceId, key])
  @@index([workspaceId, channel, active])
}

model CrmCommunicationTemplateVersion {
  id               String                   @id @default(cuid())
  templateId       String
  template         CrmCommunicationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version          Int
  subject          String?
  body             String
  active           Boolean                  @default(true)
  createdById      String?
  createdAt        DateTime                 @default(now())
  deliveryAttempts CrmDeliveryAttempt[]

  @@unique([templateId, version])
  @@index([templateId, active, version])
}

model CrmWorkspaceCommunicationPolicy {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  timezone        String    @default("Asia/Muscat")
  quietHoursStart Int       @default(1200)
  quietHoursEnd   Int       @default(480)
  hourlyRateLimit Int       @default(50)
  retentionDays   Int       @default(365)
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CrmDeliveryAttempt {
  id                    String                           @id @default(cuid())
  workspaceId           String
  workspace             Workspace                        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId             String
  contact               CrmContact                       @relation(fields: [contactId], references: [id], onDelete: Restrict)
  leadId                String?
  lead                  CrmLead?                         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  dealId                String?
  deal                  CrmDeal?                         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  activityId            String?
  activity              CrmActivity?                     @relation(fields: [activityId], references: [id], onDelete: SetNull)
  templateVersionId     String?
  templateVersion       CrmCommunicationTemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  channel               CrmCommunicationChannel
  provider              CrmDeliveryProvider
  status                CrmDeliveryStatus                @default(DRAFT)
  destination           String
  normalizedDestination String
  idempotencyKey        String
  providerMessageId     String?
  errorCode             String?
  errorMessage          String?
  metadata              Json?
  attemptedAt           DateTime                         @default(now())
  claimedAt             DateTime?
  claimToken            String?
  submittedAt           DateTime?
  providerConfirmedAt   DateTime?
  deliveredAt           DateTime?
  failedAt              DateTime?
  bouncedAt             DateTime?
  blockedAt             DateTime?
  createdById           String?

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status, attemptedAt])
  @@index([contactId, attemptedAt])
  @@index([provider, providerMessageId])
}

model OauthLoginCode {
  id        String    @id @default(cuid())
  codeHash  String    @unique
  userId    String
  returnTo  String    @default("/dashboard")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}
