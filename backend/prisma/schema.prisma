model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  passwordLoginEnabled       Boolean   @default(true)
  authTokenVersion           Int       @default(0)
  suspendedAt                DateTime?
  suspendedReason            String?
  suspendedById              String?
  deactivatedAt              DateTime?
  deactivationReason         String?
  suspendedBy                User?     @relation("UserSuspensionsIssued", fields: [suspendedById], references: [id], onDelete: SetNull)
  suspensionsIssued          User[]    @relation("UserSuspensionsIssued")
  role      Role     @default(USER)
  googleId                    String?   @unique
  phone                       String?
  companyName                 String?
  emailVerified               Boolean   @default(false)
  emailVerifiedAt             DateTime?
  emailVerificationTokenHash  String?   @unique
  emailVerificationExpiresAt  DateTime?
  pendingEmail                String?   @unique
  emailBookingUpdates          Boolean   @default(true)
  emailSavedSearchUpdates      Boolean   @default(true)
  emailMarketingUpdates        Boolean   @default(false)
  emailChangeTokenHash        String?   @unique
  emailChangeExpiresAt        DateTime?
  passwordResetTokenHash      String?   @unique
  passwordResetExpiresAt      DateTime?
  passwordResetUsedAt         DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  listings      Listing[]
  developerProjects DeveloperProject[]
  activities    Activity[]
  bookings      Booking[]
  inquiries     Inquiry[]
  notifications Notification[] @relation("UserNotifications")
  accountSecurityEvents AccountSecurityEvent[] @relation("AccountSecurityEventUser")
  accountSecurityEventsActed AccountSecurityEvent[] @relation("AccountSecurityEventActor")
  bookingEvents BookingEvent[] @relation("BookingEventActor")
  oauthLoginCodes OauthLoginCode[]

  pmsMembershipsCreated PmsCompanyMember[] @relation("PmsMemberCreatedBy")
  pmsMemberships        PmsCompanyMember[] @relation("PmsMemberUser")
  pmsPortfoliosCreated  PmsPortfolio[] @relation("PmsPortfolioCreatedBy")
  pmsPortfoliosUpdated  PmsPortfolio[] @relation("PmsPortfolioUpdatedBy")
  pmsTenantPortalAccesses PmsTenantPortalAccess[] @relation("PmsTenantPortalAccessUser")
  pmsTenantPortalAccessesCreated PmsTenantPortalAccess[] @relation("PmsTenantPortalAccessCreatedBy")
  pmsEntitlementsCreated PmsCompanyEntitlement[] @relation("PmsEntitlementCreatedBy")
  pmsEntitlementsUpdated PmsCompanyEntitlement[] @relation("PmsEntitlementUpdatedBy")
  pmsPropertiesCreated   PmsProperty[] @relation("PmsPropertyCreatedBy")
  pmsPropertiesUpdated   PmsProperty[] @relation("PmsPropertyUpdatedBy")
  pmsUnitsCreated        PmsUnit[] @relation("PmsUnitCreatedBy")
  pmsUnitsUpdated        PmsUnit[] @relation("PmsUnitUpdatedBy")
  pmsTenantsCreated      PmsTenant[] @relation("PmsTenantCreatedBy")
  pmsTenantsUpdated      PmsTenant[] @relation("PmsTenantUpdatedBy")
  pmsLeasesCreated       PmsLease[] @relation("PmsLeaseCreatedBy")
  pmsLeasesUpdated       PmsLease[] @relation("PmsLeaseUpdatedBy")
  pmsRentDueItemsCreated PmsRentDueItem[] @relation("PmsRentDueItemCreatedBy")
  pmsRentDueItemsUpdated PmsRentDueItem[] @relation("PmsRentDueItemUpdatedBy")
  pmsRentPaymentsRecorded PmsRentPayment[] @relation("PmsRentPaymentRecordedBy")
  pmsAccountingLedgerEntriesCreated PmsAccountingLedgerEntry[] @relation("PmsAccountingLedgerEntryCreatedBy")
  pmsAccountingLedgerEntriesUpdated PmsAccountingLedgerEntry[] @relation("PmsAccountingLedgerEntryUpdatedBy")
  pmsWorkOrdersCreated   PmsWorkOrder[] @relation("PmsWorkOrderCreatedBy")
  pmsWorkOrdersUpdated   PmsWorkOrder[] @relation("PmsWorkOrderUpdatedBy")
  pmsVendorsCreated      PmsVendor[] @relation("PmsVendorCreatedBy")
  pmsVendorsUpdated      PmsVendor[] @relation("PmsVendorUpdatedBy")
  pmsMaintenanceQuotesCreated PmsMaintenanceQuote[] @relation("PmsMaintenanceQuoteCreatedBy")
  pmsMaintenanceQuotesUpdated PmsMaintenanceQuote[] @relation("PmsMaintenanceQuoteUpdatedBy")
  pmsMaintenanceQuotesApproved PmsMaintenanceQuote[] @relation("PmsMaintenanceQuoteApprovedBy")
  pmsCommunicationTemplatesCreated PmsCommunicationTemplate[] @relation("PmsCommunicationTemplateCreatedBy")
  pmsCommunicationTemplatesUpdated PmsCommunicationTemplate[] @relation("PmsCommunicationTemplateUpdatedBy")
  pmsCommunicationLogsCreated PmsCommunicationLog[] @relation("PmsCommunicationLogCreatedBy")
  pmsCommunicationLogsSent PmsCommunicationLog[] @relation("PmsCommunicationLogSentBy")
  pmsImportBatchesCreated PmsImportBatch[] @relation("PmsImportBatchCreatedBy")
  pmsPoliciesCreated     PmsPolicy[] @relation("PmsPolicyCreatedBy")
  pmsPoliciesUpdated     PmsPolicy[] @relation("PmsPolicyUpdatedBy")
  pmsInspectionsCreated  PmsInspection[] @relation("PmsInspectionCreatedBy")
  pmsInspectionsUpdated  PmsInspection[] @relation("PmsInspectionUpdatedBy")
  pmsDocumentsUploaded   PmsDocument[] @relation("PmsDocumentUploadedBy")
  pmsDocumentsUpdated    PmsDocument[] @relation("PmsDocumentUpdatedBy")
  pmsMoveChecklistItemsCreated PmsMoveChecklistItem[] @relation("PmsMoveChecklistItemCreatedBy")
  pmsMoveChecklistItemsUpdated PmsMoveChecklistItem[] @relation("PmsMoveChecklistItemUpdatedBy")

  eligibilityMarkedListings       Listing[]          @relation("ListingEligibilityMarkedBy")
  listingVerificationReviews      Listing[]          @relation("ListingVerificationReviewedBy")
  activityVerificationReviews     Activity[]         @relation("ActivityVerificationReviewedBy")
  developerVerificationReviews    DeveloperCompany[] @relation("DeveloperVerificationReviewedBy")
  travelAgencyVerificationReviews TravelAgency[]     @relation("TravelAgencyVerificationReviewedBy")

  contractDraftsCreated RentalContractDraft[] @relation("ContractCreatedBy")
  contractsAsLandlord   RentalContractDraft[] @relation("ContractLandlord")
  contractsAsTenant     RentalContractDraft[] @relation("ContractTenant")

  rentSchedulesCreated    RentPaymentSchedule[] @relation("RentScheduleCreatedBy")
  rentSchedulesAsLandlord RentPaymentSchedule[] @relation("RentScheduleLandlord")
  rentSchedulesAsTenant   RentPaymentSchedule[] @relation("RentScheduleTenant")

  transactionsAsBuyer    MarketplaceTransaction[] @relation("TransactionBuyer")
  transactionsAsSeller   MarketplaceTransaction[] @relation("TransactionSeller")
  transactionsAsLandlord MarketplaceTransaction[] @relation("TransactionLandlord")
  transactionsAsTenant   MarketplaceTransaction[] @relation("TransactionTenant")
  transactionsAsProvider MarketplaceTransaction[] @relation("TransactionProvider")
  transactionsAsAdmin    MarketplaceTransaction[] @relation("TransactionAdmin")

  transactionParticipants TransactionParticipant[]
  transactionAuditEvents  TransactionAuditEvent[]  @relation("TransactionAuditActor")

  paymentLedgerAsPayer MarketplacePaymentLedger[] @relation("PaymentLedgerPayer")
  paymentLedgerAsPayee MarketplacePaymentLedger[] @relation("PaymentLedgerPayee")

  valuationRequestsRequested ValuationRequest[] @relation("ValuationRequestedBy")
  valuationRequestsReviewed  ValuationRequest[] @relation("ValuationReviewedBy")

  verificationRecordsSubmitted VerificationRecord[]    @relation("VerificationSubmittedBy")
  verificationRecordsReviewed  VerificationRecord[]    @relation("VerificationReviewedBy")
  documentChecklistReviews     DocumentChecklistItem[] @relation("DocumentChecklistReviewedBy")

  trustReportsSubmitted TrustReport[] @relation("TrustReportSubmittedBy")
  trustReportsReviewed  TrustReport[] @relation("TrustReportReviewedBy")

  reviewsWritten   Review[] @relation("ReviewWrittenBy")
  reviewsModerated Review[] @relation("ReviewModeratedBy")

  savedListings          SavedListing[]
  savedActivities        SavedActivity[]
  savedSearches          SavedSearch[]
  investorWatchlistItems InvestorWatchlistItem[]

  @@index([role])
  @@index([suspendedAt])
  @@index([deactivatedAt])
  @@index([suspendedById])
  @@index([googleId])
  @@index([emailVerified])
  @@index([emailVerificationExpiresAt])
  @@index([emailChangeExpiresAt])
  @@index([passwordResetExpiresAt])
  @@index([passwordResetUsedAt])
  @@index([createdAt])
}

model Landmark {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEn    String
  nameAr    String?
  cityEn    String
  cityAr    String?
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings   Listing[]
  activities Activity[]
  developerProjects DeveloperProject[]

  @@index([cityEn])
  @@index([category])
}

model DeveloperCompany {
  id              String  @id @default(cuid())
  slug            String  @unique
  nameEn          String
  nameAr          String?
  descriptionEn   String?
  descriptionAr   String?
  headquartersEn  String?
  headquartersAr  String?
  logo            String?
  phone           String?
  email           String?
  website         String?
  establishedYear Int?
  verified        Boolean @default(false)
  featured        Boolean @default(false)

  verificationStatus       VerificationStatus  @default(UNVERIFIED)
  verificationSource       VerificationSource?
  verificationNotes        String?
  verificationDate         DateTime?
  verificationExpiryDate   DateTime?
  verificationReviewedById String?
  verificationReviewedBy   User?               @relation("DeveloperVerificationReviewedBy", fields: [verificationReviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]
  projects DeveloperProject[]
  reviews  Review[]
  pmsEntitlement PmsCompanyEntitlement?
  pmsMembers     PmsCompanyMember[]
  pmsPortfolios  PmsPortfolio[]
  pmsPortfolioProperties PmsPortfolioProperty[]
  pmsMemberPropertyAccesses PmsMemberPropertyAccess[]
  pmsMemberPermissions PmsMemberPermission[]
  pmsTenantPortalAccesses PmsTenantPortalAccess[]
  pmsProperties  PmsProperty[]
  pmsUnits       PmsUnit[]
  pmsTenants     PmsTenant[]
  pmsLeases      PmsLease[]
  pmsRentDueItems PmsRentDueItem[]
  pmsRentPayments PmsRentPayment[]
  pmsAccountingLedgerEntries PmsAccountingLedgerEntry[]
  pmsWorkOrders PmsWorkOrder[]
  pmsVendors PmsVendor[]
  pmsMaintenanceQuotes PmsMaintenanceQuote[]
  pmsCommunicationTemplates PmsCommunicationTemplate[]
  pmsCommunicationLogs PmsCommunicationLog[]
  pmsImportBatches PmsImportBatch[]
  pmsPolicies PmsPolicy[]
  pmsInspections PmsInspection[]
  pmsDocuments PmsDocument[]
  pmsMoveChecklistItems PmsMoveChecklistItem[]

  @@index([verified])
  @@index([featured])
  @@index([verificationStatus])
  @@index([verificationReviewedById])
}

model TravelAgency {
  id              String  @id @default(cuid())
  slug            String  @unique
  nameEn          String
  nameAr          String?
  descriptionEn   String?
  descriptionAr   String?
  headquartersEn  String?
  headquartersAr  String?
  logo            String?
  phone           String?
  email           String?
  website         String?
  establishedYear Int?
  verified        Boolean @default(false)
  featured        Boolean @default(false)

  verificationStatus       VerificationStatus  @default(UNVERIFIED)
  verificationSource       VerificationSource?
  verificationNotes        String?
  verificationDate         DateTime?
  verificationExpiryDate   DateTime?
  verificationReviewedById String?
  verificationReviewedBy   User?               @relation("TravelAgencyVerificationReviewedBy", fields: [verificationReviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]
  reviews    Review[]

  @@index([verified])
  @@index([featured])
  @@index([verificationStatus])
  @@index([verificationReviewedById])
}

model DeveloperProject {
  id   String @id @default(cuid())
  slug String @unique

  nameEn        String
  nameAr        String?
  descriptionEn String?
  descriptionAr String?
  locationEn    String
  locationAr    String?

  mapPlaceLabel String?
  mapAddress    String?
  mapGoogleUrl  String?
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)

  completionStatus String?
  handoverDate     DateTime?
  totalUnits       Int?
  availableUnits   Int?
  bedroomsSummary  String?
  amenities        String[] @default([])
  paymentPlan      String?
  brochureUrl      String?
  masterplanUrl    String?
  videoWalkthroughUrl String?
  image            String?

  mediaQualityStatus  MediaQualityStatus @default(NOT_CHECKED)
  mediaQualityNotes   String?
  enhancedImageUrl    String?
  enhancementStatus   EnhancementStatus  @default(NOT_REQUESTED)
  enhancementProvider String?
  enhancementNotes    String?

  startingPriceAmount Decimal?       @db.Decimal(14, 3)
  priceCurrency       String?        @db.VarChar(3)
  priceQualifier      PriceQualifier @default(FROM)

  status         DeveloperProjectStatus @default(PENDING)
  rejectedReason String?

  developerId String
  developer   DeveloperCompany @relation(fields: [developerId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  nearestLandmarkId String?
  nearestLandmark   Landmark? @relation(fields: [nearestLandmarkId], references: [id], onDelete: SetNull)

  images        DeveloperProjectImage[]
  listings      Listing[]
  pmsProperties PmsProperty[]
  pmsUnits      PmsUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([developerId])
  @@index([ownerId])
  @@index([nearestLandmarkId])
  @@index([latitude, longitude])
  @@index([mediaQualityStatus])
}

model DeveloperProjectImage {
  id        String @id @default(cuid())
  url       String
  altEn     String?
  altAr     String?
  sortOrder Int    @default(0)

  projectId String
  project   DeveloperProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model Listing {
  id   String @id @default(cuid())
  slug String @unique

  title            String
  description      String
  type             String
  transaction      String
  buyerEligibility ListingBuyerEligibility[] @default([])
  location         String

  mapPlaceLabel String?
  mapAddress    String?
  mapGoogleUrl  String?
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)

  titleEn       String?
  titleAr       String?
  descriptionEn String?
  descriptionAr String?
  locationEn    String?
  locationAr    String?
  typeEn        String?
  typeAr        String?

  price          String
  priceAmount    Decimal?       @db.Decimal(14, 3)
  priceCurrency  String?        @db.VarChar(3)
  priceQualifier PriceQualifier @default(FIXED)
  priceUnit      PriceUnit?

  beds           Int
  baths          Int
  sqm            Int
  image          String
  status         ListingStatus @default(PENDING)
  rejectedReason String?
