model OauthLoginCode {
  id        String    @id @default(cuid())
  codeHash  String    @unique
  userId    String
  returnTo  String    @default("/dashboard")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}
