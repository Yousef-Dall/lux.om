model PmsImportBatch {
  id             String          @id @default(cuid())
  type           PmsImportType
  filename       String?
  status         PmsImportStatus @default(PREVIEWED)
  totalRows      Int             @default(0)
  successfulRows Int             @default(0)
  failedRows     Int             @default(0)
  metadata       Json?

  companyId String
  company   DeveloperCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User? @relation("PmsImportBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type])
  @@index([companyId, status])
  @@index([createdById])
  @@index([createdAt])
}

model PmsPolicy {
  id       String            @id @default(cuid())
  title    String
  category PmsPolicyCategory @default(GENERAL)
  body     String
  active   Boolean           @default(true)
  notes    String?

  companyId String
  company   DeveloperCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User? @relation("PmsPolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User? @relation("PmsPolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, active])
  @@index([companyId, category])
  @@index([createdById])
  @@index([updatedById])
}

model PmsInspection {
  id           String              @id @default(cuid())
  title        String
  status       PmsInspectionStatus @default(SCHEDULED)
  scheduledFor DateTime?
  completedAt  DateTime?
  notes        String?
  feedback     String?
  rating       Int?

  companyId String
  company   DeveloperCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  propertyId String
  property   PmsProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  unitId String?
  unit   PmsUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  tenantId String?
  tenant   PmsTenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  leaseId String?
  lease   PmsLease? @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User? @relation("PmsInspectionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User? @relation("PmsInspectionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  pmsDocuments PmsDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([propertyId])
  @@index([unitId])
  @@index([tenantId])
  @@index([leaseId])
  @@index([createdById])
  @@index([updatedById])
}

model PmsDocument {
  id       String            @id @default(cuid())
  type     PmsDocumentType
  title    String
  fileUrl  String
  status   PmsDocumentStatus @default(ACTIVE)
  expiryDate DateTime?
  notes    String?

  companyId String
  company   DeveloperCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  propertyId String?
  property   PmsProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  unitId String?
  unit   PmsUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  tenantId String?
  tenant   PmsTenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  leaseId String?
  lease   PmsLease? @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  workOrderId String?
  workOrder   PmsWorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  inspectionId String?
  inspection   PmsInspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)

  uploadedById String?
  uploadedBy   User? @relation("PmsDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User? @relation("PmsDocumentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type])
  @@index([companyId, status])
  @@index([companyId, expiryDate])
  @@index([propertyId])
  @@index([unitId])
  @@index([tenantId])
  @@index([leaseId])
  @@index([workOrderId])
  @@index([inspectionId])
  @@index([uploadedById])
  @@index([updatedById])
}

model PmsMoveChecklistItem {
  id          String                 @id @default(cuid())
  type        PmsMoveChecklistType
  title       String
  description String?
  status      PmsMoveChecklistStatus @default(PENDING)
  completedAt DateTime?
  notes       String?

  companyId String
  company   DeveloperCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  leaseId String
  lease   PmsLease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  propertyId String
  property   PmsProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  unitId String
  unit   PmsUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   PmsTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User? @relation("PmsMoveChecklistItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   User? @relation("PmsMoveChecklistItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type])
  @@index([companyId, status])
  @@index([leaseId])
  @@index([propertyId])
  @@index([unitId])
  @@index([tenantId])
  @@index([createdById])
  @@index([updatedById])
}

model TrustReport {
  id         String               @id @default(cuid())
  targetType ModerationTargetType
  targetId   String
  reason     ReportReason
  message    String?
  status     ModerationStatus     @default(PENDING)

  reporterName  String?
  reporterEmail String?
  reporterPhone String?

  reporterId String?
  reporter   User?   @relation("TrustReportSubmittedBy", fields: [reporterId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User?   @relation("TrustReportReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([reason])
  @@index([status])
  @@index([reporterId])
  @@index([reviewedById])
  @@index([createdAt])
}

model Review {
  id         String           @id @default(cuid())
  targetType ReviewTargetType
  targetId   String
  rating     Int
  title      String?
  body       String?
  status     ReviewStatus     @default(PENDING)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  travelAgencyId String?
  travelAgency   TravelAgency? @relation(fields: [travelAgencyId], references: [id], onDelete: Cascade)

  developerId String?
  developer   DeveloperCompany? @relation(fields: [developerId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation("ReviewWrittenBy", fields: [reviewerId], references: [id], onDelete: Cascade)

  moderatedById String?
  moderatedBy   User?   @relation("ReviewModeratedBy", fields: [moderatedById], references: [id], onDelete: SetNull)

  moderationNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([status])
  @@index([rating])
  @@index([activityId])
  @@index([travelAgencyId])
  @@index([developerId])
  @@index([listingId])
  @@index([reviewerId])
  @@index([moderatedById])
}

model SavedListing {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model SavedActivity {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, activityId])
  @@index([userId])
  @@index([activityId])
}

model SavedSearch {
  id             String                    @id @default(cuid())
  name           String
  category       String?
  query          String?
  filters        Json
  alertFrequency SavedSearchAlertFrequency @default(DASHBOARD_ONLY)
  alertsEnabled  Boolean                   @default(true)
  lastMatchedAt  DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([alertFrequency])
}

model InvestorWatchlistItem {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  valuationRequestId String?
  valuationRequest   ValuationRequest? @relation(fields: [valuationRequestId], references: [id], onDelete: SetNull)

  notes                 String?
  targetPrice           Decimal? @db.Decimal(14, 3)
  alertOnPriceChange    Boolean  @default(true)
  alertOnNewComparables Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([listingId])
  @@index([valuationRequestId])
}

model OauthLoginCode {
  id        String    @id @default(cuid())
  codeHash  String    @unique
  userId    String
  returnTo  String    @default("/dashboard")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}
