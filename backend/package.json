{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node scripts/run-with-test-env.mjs npx prisma migrate deploy && node scripts/run-with-test-env.mjs npx vitest run --config vitest.integration.config.mts",
    "test:all": "npm run test && npm run test:integration",
    "jobs:notifications:once": "tsx src/jobs/runNotificationJobs.ts",
    "verify:production-env": "tsx scripts/verifyProductionEnv.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "cloudinary": "^2.10.0",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/node": "25.6.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "prisma": "6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
