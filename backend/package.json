{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "prisma generate && tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma generate && tsx prisma/seed.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "latest",
    "compression": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "multer": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/compression": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/multer": "latest",
    "@types/node": "latest",
    "prisma": "6.19.3",
    "tsx": "latest",
    "typescript": "latest"
  }
}