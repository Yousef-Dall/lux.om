NODE_ENV=development
PORT=4000

# docker-compose.yml publishes PostgreSQL on localhost:5433
DATABASE_URL="postgresql://postgres:replace-with-your-postgres-password@localhost:5433/lux_om?schema=public"

# Use a long random value in production.
JWT_SECRET="replace-this-with-a-long-random-secret-value"

# Comma-separated allowed frontend origins.
# Production must use the real frontend URL and must not use localhost.
CORS_ORIGIN="http://localhost:5173"

# Local development storage. Production should use persistent storage.
STORAGE_DRIVER="local"
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=5

# Persistent production image storage.
# Set STORAGE_DRIVER="cloudinary" to enable these values.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="lux-om"

# Public frontend URL used in verification links.
# In production, use the real frontend domain, for example:
# FRONTEND_URL="https://lux.om"
FRONTEND_URL="http://localhost:5173"

# SMTP email delivery for production verification emails.
# Leave empty in local development to use development verification links.
# Example providers: Hostinger SMTP, SendGrid SMTP, Mailgun SMTP, Amazon SES SMTP.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="lux.om <no-reply@lux.om>"

# Google OAuth login/register.
# Keep disabled until you create credentials in Google Cloud Console.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URL="http://localhost:4000/api/auth/google/callback"

# Local/demo seed data.
# In development, SEED_PASSWORD may be left empty; seed will generate and print a strong random password.
# In production, seed refuses to run unless all seed values and destructive reset confirmations are explicit.
SEED_ADMIN_EMAIL="local-admin@example.test"
SEED_OWNER_EMAIL="local-owner@example.test"
SEED_ACTIVITY_PROVIDER_EMAIL="local-activities@example.test"
SEED_USER_EMAIL="local-user@example.test"
SEED_PASSWORD=""

# Dangerous production-only seed reset guard.
# Do not enable unless you intentionally want to wipe and reseed the production database.
ALLOW_DESTRUCTIVE_SEED=false
CONFIRM_SEED_DATABASE_RESET=""
