{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run lint:code && npm run lint:styles",
    "lint:code": "eslint . --max-warnings 133",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "format:check": "node scripts/checkFormatting.mjs",
    "format": "node scripts/checkFormatting.mjs --write",
    "verify:seo": "tsx scripts/verifyPublicSeo.ts",
    "verify:cache": "tsx scripts/verifyBuildCachePolicy.ts",
    "verify:polish": "tsx scripts/verifyFrontendPolish.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "^1.55.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "esbuild": "^0.28.1",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "stylelint": "16.26.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "^8.0.16"
  }
}
